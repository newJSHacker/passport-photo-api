# Copy to .env and adjust for your machine
DATABASE_URL=postgresql+asyncpg://postgres:postgres@127.0.0.1:5432/passport_photo
CORS_ORIGINS=http://localhost:3000
STORAGE_PATH=storage
MAX_UPLOAD_MB=10
DEBUG=true
# modnet (digital) or mediapipe
BACKGROUND_REMOVER=modnet
WATERMARK_ENABLED=true
WATERMARK_TEXT=Passport-Photo.online

# Checkout (demo mode skips Stripe and marks orders paid immediately)
CHECKOUT_DEMO_MODE=true
CHECKOUT_CURRENCY=usd
CHECKOUT_DIGITAL_PRICE_CENTS=1695
CHECKOUT_PRINT_PRICE_CENTS=1995
CHECKOUT_SUCCESS_URL=http://localhost:3000/checkout/success
CHECKOUT_CANCEL_URL=http://localhost:3000/checkout/cancel
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
